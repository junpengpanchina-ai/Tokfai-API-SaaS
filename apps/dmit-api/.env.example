# Tokfai DMIT backend env. Server-only — never copy any of these into apps/web.

# --- Runtime ------------------------------------------------------------------
NODE_ENV=development
PORT=8787
LOG_LEVEL=info

# Comma-separated list of allowed origins for CORS. Add preview deployments
# here as needed.
CORS_ALLOWED_ORIGINS=https://tokfai.com,https://www.tokfai.com,http://localhost:3000

# --- Supabase -----------------------------------------------------------------
# DMIT uses service_role for writes + supabase JWT secret for verifying
# frontend Authorization headers.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...service_role...
SUPABASE_JWT_SECRET=super-long-random-shared-with-supabase-auth

# --- API key hashing ----------------------------------------------------------
# Used as HMAC-SHA256 key when hashing sk-tokfai secrets. Rotate carefully —
# old hashes won't match after rotation. Use a 32+ byte random value.
TOKEN_PEPPER=

# Used to AES-256-GCM encrypt full API keys for owner-only reveal/copy.
# Must be at least 32 characters. Never expose this to apps/web.
TOKFAI_KEY_ENCRYPTION_SECRET=

# --- Upstream LLM provider (GRSAI, OpenAI-compatible) -------------------------
# Base host only — do NOT append /v1 (paths below already include /v1/...).
GRSAI_API_BASE=https://grsaiapi.com
GRSAI_API_KEY=
GRSAI_CHAT_COMPLETIONS_PATH=/v1/chat/completions
GRSAI_IMAGE_GENERATE_PATH=/v1/api/generate
GRSAI_CHAT_TIMEOUT_MS=90000
TOKFAI_UPSTREAM_TIMEOUT_MS=90000
TOKFAI_TOTAL_REQUEST_TIMEOUT_MS=120000
TOKFAI_CHAT_BODY_MAX_BYTES=1048576
TOKFAI_RATE_LIMIT_RPM=60
TOKFAI_RATE_LIMIT_WINDOW_MS=60000
TOKFAI_MAX_CONCURRENCY_PER_KEY=5
TOKFAI_GLOBAL_UPSTREAM_CONCURRENCY=50
# Upstream image-to-image field mapping:
# images_url (default) | image_url | imageUrl | input_image | referenceImages | images_data_url
GRSAI_IMAGE_INPUT_MODE=images_url
IMAGE_REQUEST_TIMEOUT_MS=120000

# --- Stripe -------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Optional Stripe Price ids (price_...) per recharge tier. When set, Checkout uses
# these instead of ad-hoc price_data when recharge_plans.stripe_price_id is null.
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_BUSINESS=

# Allowed amounts (USD whole dollars) for /v1/billing/checkout
BILLING_ALLOWED_AMOUNTS=10,25,50,100

# Allowed origins for success_url / cancel_url (defense-in-depth open redirect)
BILLING_ALLOWED_REDIRECT_ORIGINS=https://tokfai.com,http://localhost:3000
