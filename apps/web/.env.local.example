# Tokfai frontend env vars
#
# Frontend may ONLY hold public values. Anything that needs a server-only
# secret (SUPABASE_SERVICE_ROLE_KEY, STRIPE_SECRET_KEY, upstream provider API keys,
# TOKEN_PEPPER, STRIPE_WEBHOOK_SECRET) belongs in the DMIT backend.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
NEXT_PUBLIC_DMIT_API_BASE=https://api.tokfai.com
# Optional alias for DMIT origin (no trailing /v1 — paths include /v1/... in code).
# NEXT_PUBLIC_API_BASE_URL=https://api.tokfai.com
# Comma-separated admin emails allowed to open /admin/* (also supports ADMIN_EMAILS on the server).
# Default allowlist always includes junpengpanchina@gmail.com.
NEXT_PUBLIC_ADMIN_EMAILS=junpengpanchina@gmail.com
